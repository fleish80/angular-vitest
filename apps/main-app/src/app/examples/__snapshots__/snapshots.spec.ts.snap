exports[`Snapshot of Strings > should snapshot multi-line HTML 1`] = `
"<div class="card">
  <h2>Product Name</h2>
  <p class="price">$29.99</p>
  <button class="add-to-cart">Add to Cart</button>
</div>"
`;

exports[`Snapshot with Dynamic Values > should snapshot with asymmetric matchers for dynamic fields 1`] = `
{
  "createdAt": Any<Date>,
  "id": Any<String>,
  "name": "Bob",
  "role": "admin",
}
`;

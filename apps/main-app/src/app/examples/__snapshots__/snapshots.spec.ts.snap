// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`File Snapshots > should snapshot a config object 1`] = `
{
  "apiUrl": "https://api.example.com",
  "features": [
    "auth",
    "logging",
    "cache",
  ],
  "retries": 3,
  "timeout": 5000,
}
`;

exports[`File Snapshots > should snapshot an array of items 1`] = `
[
  {
    "active": true,
    "id": 1,
    "name": "Item A",
  },
  {
    "active": false,
    "id": 2,
    "name": "Item B",
  },
  {
    "active": true,
